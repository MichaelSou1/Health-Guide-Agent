# =========================
# LLM / 在线能力（必填）
# =========================
# 硅基流动 API Key（必填，否则无法对话）
# 获取方式: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# 硅基流动模型名（可按账号权限替换）
SILICONFLOW_MODEL=Pro/MiniMaxAI/MiniMax-M2.5

# Metaso 检索 API Key（可选）
# 留空时，联网搜索工具会提示缺少 Key，不影响本地 RAG 功能。
# 获取方式: https://metaso.cn/
METASO_API_KEY=your_metaso_api_key_here

# =========================
# 项目数据路径（可选）
# =========================
PROFILE_STORE_PATH=profile_store.json
KNOWLEDGE_BASE_DIR=knowledge_base

# 分层知识库子目录（可选）
KNOWLEDGE_BASE_SHARED_SUBDIR=shared

# =========================
# RAG 模型（可选，默认已针对 8GB 显存 + 中英双语语料调优）
# =========================
# 默认 embedding: BAAI/bge-m3（多语言,支持 zh+en,8192 上下文）
# 如需切回中文单语小模型以节省显存,可改为 BAAI/bge-small-zh-v1.5
RAG_EMBED_MODEL_NAME=BAAI/bge-m3
RAG_RERANK_MODEL_NAME=BAAI/bge-reranker-base
RAG_DEVICE=auto
RAG_RETRIEVE_TOP_K=12
RAG_FINAL_TOP_K=4
RAG_EMBED_BATCH_SIZE=32
RAG_RERANK_BATCH_SIZE=16
